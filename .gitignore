# =========================================================
# SIGC — Sistema Integrado de Gestão de Cascos
# .gitignore
# =========================================================


# ---------------------------------------------------------
# Ambiente virtual Python
# ---------------------------------------------------------

.venv/
venv/
env/


# ---------------------------------------------------------
# Cache e arquivos compilados do Python
# ---------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class


# ---------------------------------------------------------
# Configurações locais de desenvolvimento
# ---------------------------------------------------------

.vscode/
.idea/


# ---------------------------------------------------------
# Variáveis de ambiente e configurações sensíveis
# ---------------------------------------------------------

.env
.env.*


# ---------------------------------------------------------
# Banco de dados local de desenvolvimento
# ---------------------------------------------------------

*.db
*.sqlite
*.sqlite3


# ---------------------------------------------------------
# Backups locais
# ---------------------------------------------------------

backups/
*.bak


# ---------------------------------------------------------
# Logs locais
# ---------------------------------------------------------

logs/
*.log


# ---------------------------------------------------------
# Arquivos temporários
# ---------------------------------------------------------

*.tmp
*.temp


# ---------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini